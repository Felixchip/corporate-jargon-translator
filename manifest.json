{
  "manifest_version": 3,
  "name": "Corporate Jargon Translator",
  "version": "2.0.0",
  "description": "Floating jargon translator that watches your meetings.",

  "permissions": [
    "storage",
    "offscreen"
  ],

  "host_permissions": [
    "https://corporate-jargon-translator-production.up.railway.app/*"
  ],

  "background": {
    "service_worker": "service-worker.js"
  },

  "action": {
    "default_title": "Corporate Jargon Translator",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
