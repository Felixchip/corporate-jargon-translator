{
  "manifest_version": 3,
  "name": "Cut the BS",
  "version": "2.0.0",
  "description": "Real-time corporate jargon translator. Click the icon, speak freely, and watch the BS get decoded — live, on any page.",

  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "tabs",
    "offscreen"
  ],

  "host_permissions": [
    "*://*/*"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content/content.css"],
      "js": ["content/content.js", "content/receiver.js"]
    }
  ],

  "background": {
    "service_worker": "service-worker.js"
  },

  "web_accessible_resources": [
    {
      "resources": ["upgrade/*", "microphone/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "action": {
    "default_title": "Cut the BS",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
