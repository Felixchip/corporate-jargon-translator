{
  "manifest_version": 3,
  "name": "Corporate Jargon Translator",
  "version": "2.0.7",
  "description": "Floating jargon translator that watches your meetings.",

  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],

  "host_permissions": [
    "https://corporate-jargon-translator-production.up.railway.app/*",
    "https://*.youtube.com/*",
    "https://meet.google.com/*",
    "https://*.zoom.us/*",
    "https://*.teams.microsoft.com/*",
    "https://*.webex.com/*"
  ],

  "background": {
    "service_worker": "service-worker.js"
  },

  "action": {
    "default_title": "Corporate Jargon Translator",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
