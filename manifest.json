{
  "manifest_version": 3,
  "name": "Corporate Jargon Translator",
  "version": "2.0.7",
  "description": "Floating jargon translator that watches your meetings.",

  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],

  "host_permissions": [
    "*://*/*"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content/content.css"],
      "js": ["content/receiver.js"]
    }
  ],

  "background": {
    "service_worker": "service-worker.js"
  },

  "web_accessible_resources": [
    {
      "resources": ["upgrade/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "action": {
    "default_title": "Corporate Jargon Translator",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
