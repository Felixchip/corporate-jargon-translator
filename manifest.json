{
  "manifest_version": 3,
  "name": "Corporate Jargon Translator",
  "version": "1.0.0",
  "description": "Translates corporate jargon into brutally honest, sarcastic translations in real-time during calls.",

  "permissions": [
    "sidePanel",
    "storage"
  ],

  "host_permissions": [
    "https://api.anthropic.com/*"
  ],

  "background": {
    "service_worker": "service-worker.js"
  },

  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },

  "action": {
    "default_title": "Corporate Jargon Translator",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["permission/permission.html"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
